<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ page_title }}</title>
    {{ content_for_header }}
    
    {{ 'index.css' | asset_url | stylesheet_tag }}
    <script>
      window.ShopifyThemeSettings = {
        {% if settings.logo %}
        logoUrl: {{ settings.logo | image_url | json }},
        {% else %}
        logoUrl: null,
        {% endif %}
        
        {% if settings.hero_image %}
        heroImgUrl: {{ settings.hero_image | image_url | json }},
        {% else %}
        heroImgUrl: null,
        {% endif %}
        
        {% if settings.shape_image %}
        shapeImgUrl: {{ settings.shape_image | image_url | json }},
        {% else %}
        shapeImgUrl: null,
        {% endif %}

        {% if settings.brand_story_image %}
        brandStoryImgUrl: {{ settings.brand_story_image | image_url | json }},
        {% else %}
        brandStoryImgUrl: null,
        {% endif %}

        {% if settings.insta_img_1 %}
        insta1: {{ settings.insta_img_1 | image_url | json }},
        {% else %}
        insta1: null,
        {% endif %}

        {% if settings.insta_img_2 %}
        insta2: {{ settings.insta_img_2 | image_url | json }},
        {% else %}
        insta2: null,
        {% endif %}

        {% if settings.insta_img_3 %}
        insta3: {{ settings.insta_img_3 | image_url | json }},
        {% else %}
        insta3: null,
        {% endif %}

        {% if settings.insta_img_4 %}
        insta4: {{ settings.insta_img_4 | image_url | json }},
        {% else %}
        insta4: null,
        {% endif %}

        {% if settings.insta_img_5 %}
        insta5: {{ settings.insta_img_5 | image_url | json }},
        {% else %}
        insta5: null,
        {% endif %}

        {% if settings.insta_img_6 %}
        insta6: {{ settings.insta_img_6 | image_url | json }},
        {% else %}
        insta6: null,
        {% endif %}

        shopName: {{ shop.name | json }},
        fallbackLogoUrl: {{ 'azami-logo.png' | asset_url | json }},
        designMode: {% if request.design_mode %}true{% else %}false{% endif %}
      };

      window.ShopifyInventory = {
        {% paginate collections.all.products by 1000 %}
          {% for product in collections.all.products %}
            "{{ product.handle }}": {
              {% for variant in product.variants %}
                "{{ variant.id }}": {{ variant.inventory_quantity | default: 0 }}{% unless forloop.last %},{% endunless %}
              {% endfor %}
            }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        {% endpaginate %}
      };

      window.ShopifyNavigation = [
        {% for link in linklists.main-menu.links %}
          {
            "title": {{ link.title | json }},
            "url": {{ link.url | json }},
            "handle": {{ link.handle | json }},
            "links": [
              {% for sub_link in link.links %}
                {
                  "title": {{ sub_link.title | json }},
                  "url": {{ sub_link.url | json }},
                  "handle": {{ sub_link.handle | json }}
                }{% unless forloop.last %},{% endunless %}
              {% endfor %}
            ]
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ];

      window.ShopifyCollections = {
        {% for collection in collections %}
          "{{ collection.handle }}": {
            "title": {{ collection.title | json }},
            "products": [
              {% for product in collection.products %}
                {{ product.handle | json }}{% unless forloop.last %},{% endunless %}
              {% endfor %}
            ]
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      };
    </script>
  </head>
  <body>
    <!-- 
      You can add header sections here later, e.g.:
      {% section 'header' %} 
    -->

    <main role="main" id="root">
      {{ content_for_layout }}
    </main>
    
    <!-- 
      You can add footer sections here later, e.g.:
      {% section 'footer' %} 
    -->

    <script src="{{ 'index.js' | asset_url }}" defer="defer"></script>
  </body>
</html>
